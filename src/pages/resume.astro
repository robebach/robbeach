---

<SiteLayout
	title="Resume | Robert Beach"
	description="Resume for Robert Beach."
	active="resume"
>
	<section class="mb-4">
		<p class="text-uppercase small text-secondary fw-semibold mb-2">Resume</p>
		<div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3">
			<div class="content-measure">
				<h1 class="display-6 fw-semibold mb-2">Robert Beach</h1>
				<p class="lead text-secondary mb-2">
					R&D Systems Architect | Physical-Digital Product Architecture, Modeling Engines,
					HVAC & Building Simulation
				</p>
				<p class="text-secondary mb-0">Phoenix, Arizona, United States</p>
			</div>
			<div class="d-flex flex-wrap gap-2 no-print">
				<a class="btn btn-outline-primary flex-shrink-0" href="mailto:robert.k.beach@gmail.com">
					Contact
				</a>
				<button class="btn btn-primary flex-shrink-0" type="button" onclick="window.print()">
					Print / Save PDF
				</button>
			</div>
		</div>
	</section>

	<section class="resume-section">
		<div class="card">
			<div class="card-body">
				<h2 class="h4 mb-3">Profile</h2>
				<p class="text-secondary mb-0">
					Systems architect working at the intersection of building physics,
					computational modeling, and product architecture. I build modeling engines,
					data pipelines, and product frameworks that make complex HVAC behavior more
					predictable, verifiable, and useful across design, field, controls, product,
					and engineering workflows.
				</p>
			</div>
		</div>
	</section>

	<section class="resume-section">
		<h2 class="h4 mb-3">Highlights</h2>
		<div class="row g-3">
			{
				highlights.map((highlight) => (
					<div class="col-md-6">
						<div class="card h-100">
							<div class="card-body py-3">
								<p class="mb-0">{highlight}</p>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</section>

	<section class="resume-section">
		<h2 class="h4 mb-3">Selected Technical Work</h2>
		<div class="row g-3">
			{
				selectedWork.map((item) => (
					<div class="col-lg-6">
						<article class="card h-100">
							<div class="card-body">
								<h3 class="h6">{item.title}</h3>
								<p class="small text-secondary mb-0">{item.description}</p>
							</div>
						</article>
					</div>
				))
			}
		</div>
	</section>

	<section class="resume-section">
		<h2 class="h4 mb-3">Experience</h2>
		<div class="vstack gap-3">
			{
				experience.map((item) => (
					<article class="card">
						<div class="card-body">
							<div class="d-flex flex-column flex-md-row justify-content-between gap-2">
								<div>
									<h3 class="h5 mb-1">{item.role}</h3>
									<p class="text-secondary mb-1">{item.org}</p>
									<p class="small text-secondary mb-2">{item.location}</p>
								</div>
								<p class="small text-secondary mb-0">{item.time}</p>
							</div>
							<ul class="mb-0">
								{item.points.map((point) => (
									<li>{point}</li>
								))}
							</ul>
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="resume-section">
		<h2 class="h4 mb-3">Skills</h2>
		<div class="row g-3">
			{
				skillGroups.map((group) => (
					<div class="col-lg-6">
						<div class="card h-100">
							<div class="card-body">
								<h3 class="h6">{group.name}</h3>
								<div class="d-flex flex-wrap gap-2">
									{group.skills.map((skill) => (
										<span class="badge text-bg-light border">{skill}</span>
									))}
								</div>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</section>

	<section class="resume-section">
		<h2 class="h4 mb-3">Education</h2>
		<div class="vstack gap-3">
			{
				education.map((item) => (
					<article class="card">
						<div class="card-body">
							<div class="d-flex flex-column flex-md-row justify-content-between gap-2">
								<div>
									<h3 class="h5 mb-1">{item.school}</h3>
									<p class="text-secondary mb-1">{item.degree}</p>
									{
										item.details && (
											<ul class="small text-secondary mb-0">
												{item.details.map((detail) => (
													<li>{detail}</li>
												))}
											</ul>
										)
									}
								</div>
								<p class="small text-secondary mb-0">{item.time}</p>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="resume-section">
		<div class="row g-3">
			<div class="col-lg-6">
				<h2 class="h4 mb-3">Publications</h2>
				<div class="list-group">
					{
						publications.map((item) => (
							<div class="list-group-item">
								<h3 class="h6 mb-1">
									{
										item.href ? (
											<a href={item.href} target="_blank" rel="noreferrer">
												{item.title}
											</a>
										) : (
											item.title
										)
									}
								</h3>
								<p class="small text-secondary mb-0">
									{item.source} · {item.date}
								</p>
								<p class="small text-secondary mt-2 mb-0">{item.description}</p>
							</div>
						))
					}
				</div>
			</div>
			<div class="col-lg-6">
				<h2 class="h4 mb-3">Patents</h2>
				<div class="list-group">
					{
						patents.map((item) => (
							<div class="list-group-item">
								<h3 class="h6 mb-1">
									<a href={item.href} target="_blank" rel="noreferrer">
										{item.title}
									</a>
								</h3>
								<p class="small text-secondary mb-0">
									{item.id} · {item.date}
								</p>
								<p class="small text-secondary mt-2 mb-0">{item.description}</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="resume-section">
		<h2 class="h4 mb-3">Volunteering</h2>
		<div class="list-group">
			{
				volunteering.map((item) => (
					<div class="list-group-item">
						<div class="d-flex flex-column flex-md-row justify-content-between gap-2">
							<div>
								<h3 class="h6 mb-1">{item.role}</h3>
								<p class="small text-secondary mb-1">{item.org}</p>
								<p class="small text-secondary mb-0">{item.details}</p>
							</div>
							<p class="small text-secondary mb-0">{item.time}</p>
						</div>
					</div>
				))
			}
		</div>
	</section>

	<section class="resume-section">
		<h2 class="h4 mb-3">Contact</h2>
		<div class="list-group">
			{
				contactLinks.map((link) => (
					<a class="list-group-item list-group-item-action" href={link.href}>
						{link.label}
					</a>
				))
			}
		</div>
	</section>
</SiteLayout>
