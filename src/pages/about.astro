---
import SiteLayout from "../layouts/SiteLayout.astro";

const values = ["Practical systems", "Clear writing", "Simple interfaces", "Reliable delivery"];
---

<SiteLayout
	title="About | Robert Beach"
	description="About Robert Beach."
	active="about"
>
	<section class="mb-4">
		<p class="text-uppercase small text-secondary fw-semibold mb-2">About</p>
		<h1 class="display-6 fw-semibold mb-2">About Me</h1>
		<p class="lead text-secondary content-measure mb-0">
			I'm trained as an architect, the kind that designs buildings. 
			I've become more of a systems architect, who creates systems for homes.
			I've developed software, studied building science, mechanical engineering, energy modeling, data analytics, systems engineering, product design.
			I could be considered a computational specialist, which I have applied in diverse ways.
			A unifying thread in my career is software as a means but also the output of my work. 
			I tend to ask the question about how software might apply or enhance what I'm doing.
			I look to the software industry for inspiration. The way they work to develop tools is 
			how I'd like to see buildings built.
		</p>
	</section>

	<div class="row g-4">
		<section class="col-lg-7">
			<h2 class="h4 mb-3">Working Style</h2>
			<p class="text-secondary">
				This page is structured for a clear bio without a big promotional wrapper. Use it
				for the human context: background, interests, tools, and the way you approach
				problems.
			</p>
			<div class="d-flex flex-wrap gap-2">
				{
					values.map((value) => (
						<span class="badge text-bg-light border">{value}</span>
					))
				}
			</div>
		</section>
		<section class="col-lg-5">
			<h2 class="h4 mb-3">Contact</h2>
			<div class="list-group">
				<a class="list-group-item list-group-item-action" href="mailto:robert.k.beach@gmail.com">
					robert.k.beach@gmail.com
				</a>
				<a class="list-group-item list-group-item-action" href="https://github.com/robebach">
					GitHub
				</a>
				<a class="list-group-item list-group-item-action" href="https://www.linkedin.com/in/robert-beach-28167b11/">
					LinkedIn
				</a>
			</div>
		</section>
	</div>
</SiteLayout>
