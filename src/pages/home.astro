---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="Home Vivarium & IoT Dashboard | Robert Beach"
	description="Dashboard for Vivarium monitoring and home integrations."
	active="home-section"
>
	<!-- Client-side Password Screen -->
	<div id="login-screen" class="d-none">
		<div class="row justify-content-center py-5">
			<div class="col-md-5">
				<div class="card glass-card shadow-lg border-0 text-center p-4 py-5">
					<div class="lock-icon mb-4">🔒</div>
					<h2 class="h3 fw-semibold mb-2">Home Dashboard</h2>
					<p class="text-secondary small mb-4">Enter password to access vivarium monitoring and home systems.</p>
					
					<form id="login-form">
						<div class="mb-3">
							<input type="password" id="password-input" class="form-control form-control-lg text-center" placeholder="Password" required />
							<div id="login-error" class="text-danger small mt-2 d-none">Incorrect password. Please try again!</div>
						</div>
						<button type="submit" class="btn btn-primary btn-lg w-100 py-3 mt-2">Unlock Dashboard</button>
					</form>
					<p class="text-muted small mt-4">Hint: The password is a 8-letter name of a crested gecko.</p>
				</div>
			</div>
		</div>
	</div>

	<!-- Dashboard Screen -->
	<div id="dashboard-screen" class="d-none">
		<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
			<div>
				<p class="text-uppercase small text-secondary fw-semibold mb-2">IoT Integration</p>
				<h1 class="display-6 fw-semibold mb-2">Vivarium & Smart Home</h1>
			</div>
			<button id="logout-btn" class="btn btn-outline-danger btn-sm">Lock Dashboard</button>
		</div>

		<!-- Gecko Spotlight & Stats -->
		<div class="row g-4 mb-4">
			<div class="col-lg-4">
				<div class="card gecko-card border-0 text-white h-100 shadow-sm position-relative overflow-hidden">
					<div class="gecko-card-overlay"></div>
					<div class="card-body d-flex flex-column align-items-center text-center justify-content-center p-4">
						<div class="avatar-container mb-3 position-relative">
							<span class="gecko-avatar">🦎</span>
							<span class="status-pulse"></span>
						</div>
						<h2 class="h3 fw-bold mb-1">Penelope</h2>
						<p class="small text-light-green mb-3">Crested Gecko (Correlophus ciliatus)</p>
						
						<div class="badge-status mb-4">
							Currently: <strong>Sleeping 😴</strong>
						</div>
						
						<div class="w-100 border-top border-light-green pt-3 mt-2 text-start">
							<div class="d-flex justify-content-between mb-2">
								<span class="text-light-green-text">Current Temp</span>
								<span class="fw-semibold">74.8 °F</span>
							</div>
							<div class="d-flex justify-content-between mb-2">
								<span class="text-light-green-text">Humidity</span>
								<span class="fw-semibold">64%</span>
							</div>
							<div class="d-flex justify-content-between">
								<span class="text-light-green-text">Mister Status</span>
								<span class="fw-semibold text-warning">Idle (Next: 8:00 PM)</span>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col-lg-8">
				<div class="card border-0 h-100 shadow-sm p-4">
					<div class="d-flex justify-content-between align-items-center mb-3">
						<h3 class="h5 fw-semibold mb-0">Telemetry (24h History)</h3>
						<span class="badge text-bg-light border text-secondary">Plotly.js Chart</span>
					</div>
					<div id="plotly-chart" class="w-100" style="min-height: 280px;"></div>
				</div>
			</div>
		</div>

		<!-- Google Home Integrations -->
		<div class="row g-4">
			<div class="col-md-6">
				<div class="card border-0 shadow-sm p-4 h-100">
					<h3 class="h5 fw-semibold mb-3">Vivarium Controls</h3>
					<div class="list-group list-group-flush">
						<div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
							<div>
								<h4 class="h6 mb-1">Daylight Cycle</h4>
								<p class="text-secondary small mb-0">Smart LED bar simulating sunrise/sunset</p>
							</div>
							<div class="form-check form-switch">
								<input class="form-check-input" type="checkbox" role="switch" id="daylight-switch" checked />
							</div>
						</div>
						<div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
							<div>
								<h4 class="h6 mb-1">Night Heat (Ceramic Heat Emitter)</h4>
								<p class="text-secondary small mb-0">Automatic thermostat keeping minimum 70°F</p>
							</div>
							<div class="form-check form-switch">
								<input class="form-check-input" type="checkbox" role="switch" id="heat-switch" />
							</div>
						</div>
						<div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
							<div>
								<h4 class="h6 mb-1">Misting System</h4>
								<p class="text-secondary small mb-0">Dual nozzle high-pressure mist pump</p>
							</div>
							<div class="d-flex align-items-center gap-2">
								<button id="trigger-mist" class="btn btn-sm btn-outline-primary">Trigger 15s</button>
								<div class="form-check form-switch ms-2">
									<input class="form-check-input" type="checkbox" role="switch" id="mister-switch" checked />
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col-md-6">
				<div class="card border-0 shadow-sm p-4 h-100">
					<h3 class="h5 fw-semibold mb-3">Google Home & IoT Devices</h3>
					<div class="list-group list-group-flush">
						<div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
							<div>
								<h4 class="h6 mb-1">Living Room Main Lights</h4>
								<p class="text-secondary small mb-0">Smart dimmers</p>
							</div>
							<div class="d-flex align-items-center gap-3">
								<span class="small text-secondary">80%</span>
								<div class="form-check form-switch">
									<input class="form-check-input" type="checkbox" role="switch" id="lr-switch" checked />
								</div>
							</div>
						</div>
						<div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
							<div>
								<h4 class="h6 mb-1">Office Smart Plug</h4>
								<p class="text-secondary small mb-0">Desk accessories & monitors</p>
							</div>
							<div class="form-check form-switch">
								<input class="form-check-input" type="checkbox" role="switch" id="office-switch" checked />
							</div>
						</div>
						<div class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
							<div>
								<h4 class="h6 mb-1">Thermostat Mode</h4>
								<p class="text-secondary small mb-0">Nest Integration (Current: Cooling to 73°F)</p>
							</div>
							<span class="badge bg-primary text-uppercase px-2 py-1">Cool</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Script tags for CDNs and Client logic -->
	<script src="https://cdn.plot.ly/plotly-2.24.1.min.js" is:inline></script>

	<script is:inline>
		// Client-side authentication logic
		const PASSWORD = "penelope";
		const loginScreen = document.getElementById("login-screen");
		const dashboardScreen = document.getElementById("dashboard-screen");
		const loginForm = document.getElementById("login-form");
		const passwordInput = document.getElementById("password-input");
		const loginError = document.getElementById("login-error");
		const logoutBtn = document.getElementById("logout-btn");

		function checkAuth() {
			if (sessionStorage.getItem("authenticated") === "true") {
				loginScreen.classList.add("d-none");
				dashboardScreen.classList.remove("d-none");
				renderChart();
			} else {
				loginScreen.classList.remove("d-none");
				dashboardScreen.classList.add("d-none");
			}
		}

		loginForm.addEventListener("submit", (e) => {
			e.preventDefault();
			if (passwordInput.value.toLowerCase() === PASSWORD) {
				sessionStorage.setItem("authenticated", "true");
				loginError.classList.add("d-none");
				passwordInput.value = "";
				checkAuth();
			} else {
				loginError.classList.remove("d-none");
				// Shake animation
				const card = loginForm.closest('.card');
				card.classList.add("shake");
				setTimeout(() => card.classList.remove("shake"), 500);
			}
		});

		logoutBtn.addEventListener("click", () => {
			sessionStorage.removeItem("authenticated");
			checkAuth();
		});

		// Run auth check on load
		checkAuth();

		// Plotly Chart rendering
		function renderChart() {
			const chartDiv = document.getElementById("plotly-chart");
			if (!chartDiv) return;

			// Mock data for 24h
			const times = [];
			const temp = [];
			const humidity = [];
			const now = new Date();

			for (let i = 24; i >= 0; i--) {
				const d = new Date(now.getTime() - i * 60 * 60 * 1000);
				const hours = d.getHours();
				times.push(d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
				
				// Base temp & humidity changes based on time of day
				let baseTemp = 74;
				let baseHum = 65;
				if (hours >= 8 && hours <= 18) {
					baseTemp += Math.sin((hours - 8) / 10 * Math.PI) * 4; // Day peak
					baseHum -= Math.sin((hours - 8) / 10 * Math.PI) * 15; // Day dip
				} else {
					baseTemp -= 2; // Night cool
					baseHum += 10; // Night rise
				}
				
				temp.push(Number((baseTemp + Math.random() * 0.6).toFixed(1)));
				humidity.push(Number((baseHum + Math.random() * 2).toFixed(0)));
			}

			const tempTrace = {
				x: times,
				y: temp,
				name: 'Temperature (°F)',
				type: 'scatter',
				line: { color: '#ef4444', width: 3 },
				marker: { size: 6 }
			};

			const humTrace = {
				x: times,
				y: humidity,
				name: 'Humidity (%)',
				yaxis: 'y2',
				type: 'scatter',
				line: { color: '#06b6d4', width: 3 },
				marker: { size: 6 }
			};

			const data = [tempTrace, humTrace];

			const layout = {
				margin: { t: 30, b: 40, l: 40, r: 40 },
				showlegend: true,
				legend: { orientation: 'h', y: -0.2 },
				plot_bgcolor: 'transparent',
				paper_bgcolor: 'transparent',
				xaxis: {
					gridcolor: 'rgba(0,0,0,0.05)',
					tickangle: -45,
					tickfont: { size: 10 }
				},
				yaxis: {
					title: 'Temperature (°F)',
					titlefont: { color: '#ef4444' },
					tickfont: { color: '#ef4444' },
					gridcolor: 'rgba(0,0,0,0.05)'
				},
				yaxis2: {
					title: 'Humidity (%)',
					titlefont: { color: '#06b6d4' },
					tickfont: { color: '#06b6d4' },
					overlaying: 'y',
					side: 'right',
					gridcolor: 'rgba(0,0,0,0.05)'
				}
			};

			const config = { responsive: true, displayModeBar: false };

			Plotly.newPlot(chartDiv, data, layout, config);
		}

		// Trigger mist button effect
		const triggerBtn = document.getElementById("trigger-mist");
		if (triggerBtn) {
			triggerBtn.addEventListener("click", () => {
				const originalText = triggerBtn.innerText;
				triggerBtn.disabled = true;
				triggerBtn.innerText = "Misting... 💦";
				setTimeout(() => {
					triggerBtn.disabled = false;
					triggerBtn.innerText = originalText;
				}, 15000);
			});
		}
	</script>

	<style>
		/* Shake animation for password entry */
		@keyframes shake {
			0%, 100% { transform: translateX(0); }
			20%, 60% { transform: translateX(-10px); }
			40%, 80% { transform: translateX(10px); }
		}
		.shake {
			animation: shake 0.5s ease-in-out;
		}

		/* Lock Screen styling */
		.glass-card {
			background: rgba(255, 255, 255, 0.7);
			backdrop-filter: blur(10px);
			-webkit-backdrop-filter: blur(10px);
			border: 1px solid rgba(255, 255, 255, 0.25) !important;
		}
		.lock-icon {
			font-size: 3.5rem;
			color: #0d6efd;
		}

		/* Gecko Spotlight Card */
		.gecko-card {
			background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
			border-radius: 12px;
		}
		.gecko-avatar {
			font-size: 4rem;
			display: inline-block;
			line-height: 1;
		}
		.status-pulse {
			position: absolute;
			width: 14px;
			height: 14px;
			background-color: #2ec4b6;
			border-radius: 50%;
			bottom: 2px;
			right: 2px;
			border: 2px solid #2a5298;
			box-shadow: 0 0 0 0 rgba(46, 196, 182, 0.7);
			animation: pulse 1.6s infinite;
		}
		@keyframes pulse {
			0% {
				transform: scale(0.95);
				box-shadow: 0 0 0 0 rgba(46, 196, 182, 0.7);
			}
			70% {
				transform: scale(1);
				box-shadow: 0 0 0 6px rgba(46, 196, 182, 0);
			}
			100% {
				transform: scale(0.95);
				box-shadow: 0 0 0 0 rgba(46, 196, 182, 0);
			}
		}
		.badge-status {
			display: inline-block;
			padding: 0.35rem 0.85rem;
			border-radius: 50px;
			background: rgba(255, 255, 255, 0.15);
			font-size: 0.85rem;
			backdrop-filter: blur(5px);
		}
		.text-light-green {
			color: #8be5d4;
		}
		.text-light-green-text {
			color: #bcefe5;
		}
		.border-light-green {
			border-color: rgba(139, 229, 212, 0.2) !important;
		}

		/* Switch styling overrides */
		.form-check-input:checked {
			background-color: #2ec4b6;
			border-color: #2ec4b6;
		}
	</style>
</SiteLayout>
