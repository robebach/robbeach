---
import SiteLayout from "../layouts/SiteLayout.astro";

const dashboardItems = [
	{
		label: "Portfolio",
		title: "Selected work",
		text: "A concise place for case studies, side projects, and links to shipped work.",
		href: "/portfolio",
		linkText: "View work",
	},
	{
		label: "Blog",
		title: "Recent writing",
		text: "Notes, essays, technical posts, and updates can live here without extra ceremony.",
		href: "/blog",
		linkText: "Read posts",
	},
	{
		label: "Resume",
		title: "Background",
		text: "Experience, skills, education, and contact details organized for quick scanning.",
		href: "/resume",
		linkText: "View resume",
	},
];

const focusItems = [
	"Keep the site simple, readable, and easy to update.",
	"Add portfolio entries as compact case studies.",
	"Use the blog as a lightweight running notebook.",
];
---

<SiteLayout
	title="Home | Robert Beach"
	description="Home dashboard for Robert Beach's personal site."
	active="home"
>
	<section class="mb-4">
		<div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3">
			<div class="content-measure">
				<p class="text-uppercase small text-secondary fw-semibold mb-2">Personal site</p>
				<h1 class="display-6 fw-semibold mb-2">Home Dashboard</h1>
				<p class="lead text-secondary mb-0">
					A simple index for current work, writing, background, and resume details.
				</p>
			</div>
			<a class="btn btn-primary flex-shrink-0" href="/resume">View Resume</a>
		</div>
	</section>

	<section class="row g-3 mb-4" aria-label="Site sections">
		{
			dashboardItems.map((item) => (
				<div class="col-md-4">
					<article class="card dashboard-card border">
						<div class="card-body">
							<p class="small text-uppercase text-secondary fw-semibold mb-2">
								{item.label}
							</p>
							<h2 class="h5 card-title">{item.title}</h2>
							<p class="card-text text-secondary">{item.text}</p>
							<a class="stretched-link" href={item.href}>{item.linkText}</a>
						</div>
					</article>
				</div>
			))
		}
	</section>

	<section class="row g-4">
		<div class="col-lg-7">
			<h2 class="h4 mb-3">Current Focus</h2>
			<ul class="list-group">
				{
					focusItems.map((item) => (
						<li class="list-group-item d-flex align-items-start gap-2">
							<span class="badge text-bg-primary mt-1">Now</span>
							<span>{item}</span>
						</li>
					))
				}
			</ul>
		</div>
		<div class="col-lg-5">
			<h2 class="h4 mb-3">Quick Links</h2>
			<div class="list-group">
				<a class="list-group-item list-group-item-action" href="/about">About me</a>
				<a class="list-group-item list-group-item-action" href="/portfolio">Portfolio</a>
				<a class="list-group-item list-group-item-action" href="/blog">Blog archive</a>
				<a class="list-group-item list-group-item-action" href="/resume">Resume</a>
			</div>
		</div>
	</section>
</SiteLayout>
