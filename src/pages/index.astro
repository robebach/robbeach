---
import SiteLayout from "../layouts/SiteLayout.astro";

const dashboardItems = [
	{
		label: "Projects",
		title: "Work",
		text: "Work, sketches, images, etc.",
		href: "/projects",
		linkText: "View it",
	},
	{
		label: "Blog",
		title: "Writing",
		text: "Not my traditional strong point..read at your own risk.",
		href: "/blog",
		linkText: "Read some",
	},
	{
		label: "Resume",
		title: "Background",
		text: "My Career in a nutshell",
		href: "/resume",
		linkText: "See it",
	},
];

// const focusItems = [
// 	"Rheia"",
// 	"Viva-Logger",
// 	"This site",
// ];
---

<SiteLayout
	title="Beach"
	description="Robert Beach's personal site."
	active="landing"
>
	<section class="mb-4">
		<div
			class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3"
		>
			<div class="content-measure">
				<p class="text-uppercase small text-secondary fw-semibold mb-2">
					Personal site
				</p>
				<h1 class="display-6 fw-semibold mb-2">Home</h1>
				<p class="lead text-secondary mb-0">My personal site.</p>
			</div>
			<!-- <a class="btn btn-primary flex-shrink-0" href="/resume">View Resume</a> -->
		</div>
	</section>

	<section class="row g-3 mb-4" aria-label="Site sections">
		{
			dashboardItems.map((item) => (
				<div class="col-md-4">
					<article class="card dashboard-card border">
						<div class="card-body">
							<p class="small text-uppercase text-secondary fw-semibold mb-2">
								{item.label}
							</p>
							<h2 class="h5 card-title">{item.title}</h2>
							<p class="card-text text-secondary">{item.text}</p>
							<a class="stretched-link" href={item.href}>
								{item.linkText}
							</a>
						</div>
					</article>
				</div>
			))
		}
	</section>
